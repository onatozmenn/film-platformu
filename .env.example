# Public display configuration
NEXT_PUBLIC_SITE_NAME="Film Platform"

# Local PostgreSQL only; replace for each isolated environment.
DATABASE_URL="postgresql://film:film@127.0.0.1:54329/film_platform?schema=public"
TEST_DATABASE_URL="postgresql://film:film@127.0.0.1:54329/film_platform_test?schema=public"

# Runtime behavior
SITE_ORIGIN="http://localhost:3000"
LOG_LEVEL="info"
TRUST_INCOMING_REQUEST_ID="false"

# TMDB metadata imports are off unless both values are explicitly configured.
TMDB_ENABLED="false"
TMDB_API_TOKEN=""

# Guest playback defaults to the deterministic local fake. Production selects mux.
VIDEO_PROVIDER="fake"
SUPPORTED_TERRITORIES="TR"
LOCAL_DEFAULT_TERRITORY="TR"
MUX_TOKEN_ID=""
MUX_TOKEN_SECRET=""
MUX_WEBHOOK_SECRET=""
MUX_SIGNING_KEY_ID=""
MUX_SIGNING_PRIVATE_KEY=""