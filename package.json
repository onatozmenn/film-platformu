{
  "name": "film-platform",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0 <25",
    "pnpm": "11.14.0"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"tests/**/*.{ts,tsx}\" \"scripts/**/*.ts\" \"prisma/**/*.ts\" \"*.{json,ts,mjs,yaml}\" \".github/**/*.yml\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"tests/**/*.{ts,tsx}\" \"scripts/**/*.ts\" \"prisma/**/*.ts\" \"*.{json,ts,mjs,yaml}\" \".github/**/*.yml\"",
    "test": "vitest run",
    "pretest:integration": "prisma migrate deploy --config prisma.test.config.ts && prisma db seed --config prisma.test.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "check:budgets": "tsx scripts/check-client-budgets.ts",
    "db:up": "docker compose up -d --wait postgres",
    "db:down": "docker compose down",
    "db:format": "prisma format",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:test:migrate": "prisma migrate deploy --config prisma.test.config.ts",
    "db:test:seed": "prisma db seed --config prisma.test.config.ts",
    "db:seed": "prisma db seed",
    "db:check": "prisma validate && prisma migrate status && tsx scripts/db-check.ts"
  },
  "dependencies": {
    "@mux/mux-node": "14.1.1",
    "@mux/mux-player-react": "3.13.0",
    "@next-auth/prisma-adapter": "1.0.7",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@radix-ui/react-dialog": "1.1.19",
    "lucide-react": "1.25.0",
    "next": "16.2.10",
    "next-auth": "4.24.14",
    "nodemailer": "7.0.13",
    "pg": "8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "0.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.3",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "20.19.43",
    "@types/nodemailer": "7.0.12",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "dotenv": "17.4.2",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "prisma": "7.8.0",
    "tailwindcss": "4.3.3",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "packageManager": "pnpm@11.14.0+sha512.66c1ac4c7d4762d6d7dde44c7f3e5a73591ed0a0806e751d4ed32d4f004f25b2285a906b1fd8a9e3e621df3b4e2858bf88e50e0cf626bedbe977fe434a5caf85"
}
