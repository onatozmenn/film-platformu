# Public display configuration
NEXT_PUBLIC_SITE_NAME="Film Platform"

# Local PostgreSQL only; replace for each isolated environment.
DATABASE_URL="postgresql://film:film@127.0.0.1:54329/film_platform?schema=public"
TEST_DATABASE_URL="postgresql://film:film@127.0.0.1:54329/film_platform_test?schema=public"

# Runtime behavior
SITE_ORIGIN="http://localhost:3000"
PRODUCTION_CSP_ENFORCED="false"
PRODUCTION_HSTS_ENABLED="false"
PRODUCTION_RELEASE_EVIDENCE_FILE=""
PRODUCTION_RELEASE_EVIDENCE_JSON=""
RELEASE_ID="local-development"
LOG_LEVEL="info"
TRUST_INCOMING_REQUEST_ID="false"

# TMDB metadata imports are off unless both values are explicitly configured.
TMDB_ENABLED="false"
TMDB_API_TOKEN=""

# Guest playback defaults to the deterministic local fake. Production selects mux.
VIDEO_PROVIDER="fake"
SUPPORTED_TERRITORIES="TR"
LOCAL_DEFAULT_TERRITORY="TR"
MUX_TOKEN_ID=""
MUX_TOKEN_SECRET=""
MUX_WEBHOOK_SECRET=""
MUX_SIGNING_KEY_ID=""
MUX_SIGNING_PRIVATE_KEY=""

# Advertising is off by default. The deterministic fake is allowed only outside production.
ADVERTISING_PROVIDER="disabled"
ADVERTISING_TEST_SCENARIO=""

# Optional email-link accounts are disabled unless one complete provider is selected.
AUTH_EMAIL_PROVIDER="disabled"
AUTH_SECRET=""
AUTH_EMAIL_FROM=""
AUTH_SMTP_URL=""
NEXTAUTH_URL="http://localhost:3000"

# Internal scheduled jobs are disabled unless a dedicated secret is configured.
CRON_SECRET=""
PUBLISH_BATCH_LIMIT="25"
RETENTION_BATCH_LIMIT="100"
